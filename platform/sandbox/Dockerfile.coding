FROM eclipse-temurin:8-jdk AS jdk8
FROM eclipse-temurin:17-jdk AS jdk17
FROM silicon-agent-sandbox:base

USER root

# Development toolchain
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gcc g++ make \
    nodejs npm \
    && rm -rf /var/lib/apt/lists/*

COPY --from=jdk8 /opt/java/openjdk /opt/jdk8
COPY --from=jdk17 /opt/java/openjdk /opt/jdk17

ENV JAVA8_HOME=/opt/jdk8
ENV JAVA17_HOME=/opt/jdk17
ENV JAVA_HOME=/opt/jdk17
ENV PATH="${JAVA_HOME}/bin:${PATH}"

# Common Python dev tools
RUN pip install --no-cache-dir \
    pytest ruff black mypy \
    httpx pydantic sqlalchemy aiosqlite \
    fastapi uvicorn

# Common Node.js tools
RUN npm install -g typescript tsx prettier eslint 2>/dev/null || true

USER agent
WORKDIR /workspace
CMD ["python", "/app/agent_server.py", "--port", "9090"]
